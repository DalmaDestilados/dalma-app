# --- General ---
.DS_Store
.vscode/
.idea/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Dependencias (Ignora ambas carpetas) ---
node_modules/
Backend/node_modules/
Frontend/node_modules/

# --- Variables de Entorno (CRÍTICO por seguridad) ---
