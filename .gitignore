Frontend/build/

# --- Base de Datos y Temporales ---
*.sql
*.sqlite
.temp/
.tmp/

# --- Archivos subidos por usuarios ---
# Ignoramos el contenido de uploads para no llenar el repo de fotos de prueba,
# pero mantenemos la carpeta con un archivo .gitkeep si existe.
Backend/uploads/*
!Backend/uploads/.gitkeep